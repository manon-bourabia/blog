{% extends 'base.html.twig' %}

{% block title %}Mon Blog Pro{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Bienvenue sur le Blog</h1>
            <a href="{{ path('app_blog_new') }}" class="btn btn-primary">Nouvel Article</a>
        </div>

        <div class="card bg-light mb-5 shadow-sm">
            <div class="card-body">
                <form method="get" action="{{ path('app_blog_index') }}" class="row g-3">
                    <div class="col-md-5">
                        <input type="text" name="q" class="form-control" placeholder="Rechercher un titre..." value="{{ app.request.query.get('q') }}">
                    </div>
                    <div class="col-md-4">
                        <select name="category" class="form-select">
                            <option value="">Toutes les catégories</option>
                            {% for cat in categories %}
                                <option value="{{ cat.id }}" {{ app.request.query.get('category') == cat.id ? 'selected' : '' }}>
                                    {{ cat.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-dark w-100">Filtrer</button>
                    </div>
                </form>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'info') }} mt-3">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row">
            {% for post in posts %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                <span class="badge mb-2" style="background-color: {{ post.category.color ?? '#007bff' }}; color: white;">
                                {{ post.category.name }}
                            </span>

                            {% if post.published %}
                                <span class="badge bg-success float-end">Publié</span>
                            {% else %}
                                <span class="badge bg-warning text-dark float-end">Brouillon</span>
                            {% endif %}

                            <h5 class="card-title mt-2">{{ post.title }}</h5>
                            
                            <p class="card-text text-muted">
                                {{ post.content|slice(0, 100) }}...
                            </p>
                        </div>
                        
                        <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center">
                            <small class="text-muted">Par <strong>{{ post.author }}</strong></small>
                            <a href="{{ path('app_blog_edit', {id: post.id}) }}" class="btn btn-outline-secondary btn-sm">Modifier</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center mt-5">
                    <div class="alert alert-light border shadow-sm">
                        <p class="mb-0">Aucun article trouvé pour cette recherche.</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}